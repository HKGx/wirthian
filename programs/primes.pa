integer i; integer j; integer count; integer isprime;

count := 0;
for i := 2 to 100000 do begin
    isprime := 1;
    for j := 2 to i / 2 do begin
        if j * j > i then break;
        if i % j = 0 then begin isprime := 0; break; end;
    end;
    count := count + isprime;
end;
print(count);
print("\n");
