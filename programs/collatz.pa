integer n; integer steps; integer total; integer k; integer rep;

total := 0;
for rep := 1 to 10 do begin
    for k := 1 to 10000 do begin
        n := k; steps := 0;
        for steps := 1 to 100000 do begin
            if n = 1 then break;
            if n % 2 = 0 then n := n / 2 else n := 3 * n + 1;
        end;
        total := total + steps;
    end;
end;
print(total);
print("\n");
